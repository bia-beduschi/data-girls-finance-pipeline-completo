class TestConverterCreditHistoryAge:
    def test_converte_anos_e_meses_para_total_em_meses(self, spark):
        df = spark.createDataFrame([("22 Years and 1 Months",), (None,)], ["Credit_History_Age"])
        resultado_df = converter_credit_history_age(df)
        resultado = resultado_df.collect()
        assert resultado[0]["Credit_History_Age_Months"] == 265
        assert resultado[1]["Credit_History_Age_Months"] is None
        assert "Credit_History_Age" not in resultado_df.columns


class TestPadronizarCategoricas:
    def test_placeholder_vira_unknown(self, spark):
        df = spark.createDataFrame(
            [("_______", "_", "!@9#%8"), ("Engineer", "Good", "High_spent_Small_value")],
            ["Occupation", "Credit_Mix", "Payment_Behaviour"],
        )
        resultado = padronizar_categoricas_com_placeholder(df).collect()
        assert resultado[0]["Occupation"] == "Unknown"
        assert resultado[0]["Credit_Mix"] == "Unknown"
        assert resultado[0]["Payment_Behaviour"] == "Unknown"
        assert resultado[1]["Occupation"] == "Engineer"


class TestPadronizarPaymentOfMinAmount:
    def test_nm_vira_no(self, spark):
        df = spark.createDataFrame([("NM",), ("Yes",), ("No",)], ["Payment_of_Min_Amount"])
        resultado = padronizar_payment_of_min_amount(df).collect()
        assert resultado[0]["Payment_of_Min_Amount"] == "No"
        assert resultado[1]["Payment_of_Min_Amount"] == "Yes"
        assert resultado[2]["Payment_of_Min_Amount"] == "No"


class TestRemoverColunasPii:
    def test_remove_name_e_ssn_quando_presentes(self, spark):
        df = spark.createDataFrame([("Aaron", "821-00-0265", "CUS_001")], ["Name", "SSN", "Customer_ID"])
        resultado = remover_colunas_pii(df)
        assert "Name" not in resultado.columns
        assert "SSN" not in resultado.columns
        assert "Customer_ID" in resultado.columns

    def test_nao_quebra_quando_colunas_pii_ja_ausentes(self, spark):
        df = spark.createDataFrame([("CUS_001",)], ["Customer_ID"])
        resultado = remover_colunas_pii(df)
        assert list(resultado.columns) == ["Customer_ID"]


class TestRemoverDuplicatas:
    def test_remove_linha_duplicada_por_cliente_e_mes(self, spark):
        df = spark.createDataFrame(
            [("CUS001", "January", 100), ("CUS001", "January", 100), ("CUS001", "February", 100)],
            ["Customer_ID", "Month", "Valor"],
        )
        resultado = remover_duplicatas(df)
        assert resultado.count() == 2


class TestValidarQualidadeDados:
    def _df_base(self, spark, **overrides):
        linhas = overrides.get(
            "linhas",
            [("CUS001", 50000.0, "STANDARD", "January"), ("CUS002", 60000.0, "GOOD", "January")],
        )
        return spark.createDataFrame(linhas, ["Customer_ID", "Annual_Income", "Credit_Score", "Month"])

    def test_levanta_erro_quando_customer_id_e_nulo(self, spark):
        df = spark.createDataFrame(
            [(None, 50000.0, "STANDARD", "January"), ("CUS001", 60000.0, "GOOD", "January")],
            ["Customer_ID", "Annual_Income", "Credit_Score", "Month"],
        )
        with pytest.raises(DataQualityError, match="Customer_ID nulo"):
            validar_qualidade_dados(df)

    def test_levanta_erro_quando_renda_negativa_residual(self, spark):
        df = spark.createDataFrame(
            [("CUS001", -100.0, "STANDARD", "January")],
            ["Customer_ID", "Annual_Income", "Credit_Score", "Month"],
        )
        with pytest.raises(DataQualityError, match="renda negativa"):
            validar_qualidade_dados(df)

    def test_levanta_erro_quando_ha_pii_presente(self, spark):
        df = spark.createDataFrame(
            [("CUS001", 50000.0, "STANDARD", "January", "Aaron")],
            ["Customer_ID", "Annual_Income", "Credit_Score", "Month", "Name"],
        )
        with pytest.raises(DataQualityError, match="LGPD"):
            validar_qualidade_dados(df)

    def test_levanta_erro_quando_ha_duplicata_de_cliente_e_mes(self, spark):
        df = spark.createDataFrame(
            [
                ("CUS001", 50000.0, "STANDARD", "January"),
                ("CUS001", 50000.0, "STANDARD", "January"),
            ],
            ["Customer_ID", "Annual_Income", "Credit_Score", "Month"],
        )
        with pytest.raises(DataQualityError, match="duplicada"):
            validar_qualidade_dados(df)

    def test_nao_levanta_erro_com_dados_validos(self, spark):
        df = self._df_base(spark)
        validar_qualidade_dados(df)

    def test_levanta_erro_com_dataframe_vazio(self, spark):
        df = spark.createDataFrame(
            [], "Customer_ID STRING, Annual_Income DOUBLE, Credit_Score STRING, Month STRING"
        )
        with pytest.raises(DataQualityError, match="vazio"):
            validar_qualidade_dados(df)
