class TestLimparContasCartoesEJuros:
    def test_valores_fora_do_limite_iqr_viram_nulos(self, spark):
        df = spark.createDataFrame(
            [(1500, 1200, 5000)],
            ["Num_Bank_Accounts", "Num_Credit_Card", "Interest_Rate"],
        )
        resultado = limpar_contas_cartoes_e_juros(df).collect()
        assert resultado[0]["Num_Bank_Accounts"] is None
        assert resultado[0]["Num_Credit_Card"] is None
        assert resultado[0]["Interest_Rate"] is None

    def test_valores_dentro_do_limite_sao_preservados(self, spark):
        df = spark.createDataFrame(
            [(5, 4, 10)],
            ["Num_Bank_Accounts", "Num_Credit_Card", "Interest_Rate"],
        )
        resultado = limpar_contas_cartoes_e_juros(df).collect()
        assert resultado[0]["Num_Bank_Accounts"] == 5.0
        assert resultado[0]["Num_Credit_Card"] == 4.0
        assert resultado[0]["Interest_Rate"] == 10.0


