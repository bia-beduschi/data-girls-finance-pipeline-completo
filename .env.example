# Copie este arquivo para ".env" e preencha com suas credenciais reais.
# O ".env" nunca deve ser commitado (já está protegido pelo .gitignore).

# --- Kaggle (Task 1 - Extração) ---
# Opcional: se não preencher, o pipeline usa o CSV local em data/raw/
KAGGLE_USERNAME="seu_usuario_kaggle"
KAGGLE_KEY="sua_chave_kaggle_aqui"

# --- AWS (Task 3 - Carga no S3) ---
AWS_ACCESS_KEY_ID="sua_access_key_id_aqui"
AWS_SECRET_ACCESS_KEY="sua_secret_access_key_aqui"
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=data-girls-finance-trusted-bucket

# --- Airflow (apenas quando rodando via Docker) ---
AIRFLOW_UID=50000

# --- Caminhos locais (valores padrão já funcionam sem alterar) ---
RAW_DATA_DIR=./data/raw
TRUSTED_DATA_DIR=./data/processed/credit_score_clean
